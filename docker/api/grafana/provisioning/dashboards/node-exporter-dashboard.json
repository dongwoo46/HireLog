        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 - (node_memory_MemAvailable_bytes{instance=~\"10.0.1.6:9100\"} / node_memory_MemTotal_bytes{instance=~\"10.0.1.6:9100\"} * 100)",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ]
    },

    {
      "type": "gauge",
      "id": 12,
      "title": "Disk Usage (/)",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 6 },
