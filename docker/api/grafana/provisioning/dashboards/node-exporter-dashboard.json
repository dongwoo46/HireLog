      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },

    {
      "type": "gauge",
      "id": 10,
      "title": "CPU Usage",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\", instance=~\"10.0.1.6:9100\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ]
    },

    {
      "type": "gauge",
      "id": 11,
      "title": "Memory Usage",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
