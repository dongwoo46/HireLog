      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 - (node_filesystem_avail_bytes{instance=~\"10.0.1.6:9100\", mountpoint=\"/\", fstype!=\"tmpfs\"} / node_filesystem_size_bytes{instance=~\"10.0.1.6:9100\", mountpoint=\"/\", fstype!=\"tmpfs\"} * 100)",
          "legendFormat": "Disk %",
          "refId": "A"
        }
      ]
    },

    {
      "type": "stat",
