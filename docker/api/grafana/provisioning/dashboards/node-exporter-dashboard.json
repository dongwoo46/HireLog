            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(node_disk_read_bytes_total{instance=\"10.0.0.116:9100\", device!~\"dm.*\"}[5m])",
          "legendFormat": "Read ({{device}})",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(node_disk_written_bytes_total{instance=\"10.0.0.116:9100\", device!~\"dm.*\"}[5m])",
          "legendFormat": "Write ({{device}})",
          "refId": "B"
        }
      ]
    }
  ]
}
